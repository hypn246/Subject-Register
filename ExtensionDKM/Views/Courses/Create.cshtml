@model ExtensionDKM.Models.Course

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Course</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MajorId" class="control-label"></label>
                <select asp-for="MajorId" asp-items="ViewBag.Majors">
                    <option value="" disabled selected>-- Select Major --</option>
                </select>
                <span asp-validation-for="MajorId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Credit" class="control-label"></label>
                <input asp-for="Credit" class="form-control" />
                <span asp-validation-for="Credit" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Tuition" class="control-label"></label>
                <input asp-for="Tuition" class="form-control" />
                <span asp-validation-for="Tuition" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="PreviousCourseIds" class="control-label"></label>
                <select name="PreviousCourseIds" asp-items="ViewBag.Courses" multiple>
                    <option value="" selected>-- Select Previous Courses --</option>
                </select>
                <span for="PreviousCourseIds" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="RequirementCourseIds" class="control-label"></label>
                <select name="RequirementCourseIds" asp-items="ViewBag.Courses" multiple>
                    <option value="" selected>-- Select Requirement Courses --</option>
                </select>
                <span for="RequirementCourseIds" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

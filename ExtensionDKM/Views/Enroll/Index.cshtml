@model IEnumerable<ExtensionDKM.Models.Classroom>

@{
    ViewData["Title"] = "Enroll class"; 
}

<h1>Enroll courses and class</h1>

<style>
    .registration-card {
        border: 1px solid #005eb8; 
        border-radius: 8px;
        margin-bottom: 2rem;
        overflow: hidden;
    }
    
    .registration-header {
        padding: 15px 20px;
        border-bottom: 1px solid #005eb8;
        background-color: #fff;
    }

    .registration-header h5 {
        margin: 0;
        font-size: 1.1rem;
        color: #333;
    }

    .schedule-scroll-box {
        max-height: 200px;
        overflow-y: auto;
        font-size: 0.85rem;
        color: #555;
    }

    .schedule-item {
        padding: 4px 0;
        border-bottom: 1px solid #eee;
    }

    .table-custom-header th {
        font-weight: 600;
        color: #333;
        border-bottom: 2px solid #005eb8 !important;
    }

    .filter-row input {
        border: 1px solid #ced4da;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: 0.85rem;
        width: 100%;
        color: #666;
    }
    
    .filter-row td {
        padding: 8px 4px;
        border-bottom: 1px solid #005eb8;
    }
</style>

<div class="container-fluid mt-4">

    <div class="registration-card">
        <div class="registration-header">
            <h5>
                Open courses available
                <span class="text-danger" style="font-size: 0.9rem; font-weight: normal;">@{}</span>
            </h5>
        </div>

        <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Time)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Room)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SchoolYear)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Semester)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SS)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Lecturer)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Course)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Time)
                </td>
                <td>
                            @item.Course?.Name
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SchoolYear)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Semester)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SS)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LecturerId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Course.Name)
                </td>
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                </td>
            </tr>
        }
        </tbody>
        </table>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-borderless mb-0 align-middle" style="min-width: 1000px;">
                    <thead>
                        <tr class="filter-row bg-light">
                            <td class="text-center text-primary" style="width: 40px;">
                                <i class="fas fa-search"></i>
                            </td>
                            <td style="width: 100px;"><input type="text" placeholder="..."></td>
                            <td style="width: 150px;"><input type="text" placeholder="..."></td>
                            <td style="width: 80px;"><input type="text" placeholder="..."></td>
                            <td style="width: 60px;"><input type="text" placeholder="..."></td>
                            <td style="width: 100px;"><input type="text" placeholder="..."></td>
                            <td style="width: 60px;"><input type="text" placeholder="..."></td>
                            <td style="width: 60px;"><input type="text" placeholder="..."></td>
                            <td><input type="text" placeholder="..."></td>
                        </tr>
                    </thead>
                    
                    <tbody>
                        <tr class="border-bottom">
                            <td class="text-center">
                                <input class="form-check-input" type="checkbox" value="ITEC4415" id="chk_ITEC4415">
                            </td>
                            <td class="text-secondary">ITEC4415</td>
                            <td class="text-secondary">Kiểm thử phần<br>mềm</td>
                            <td class="text-secondary text-center">IT2302</td>
                            <td class="text-secondary text-center">02</td>
                            <td class="text-secondary text-center">3</td>
                            <td class="text-secondary">DH23IT02</td>
                            <td class="text-secondary text-center">35</td>
                            <td class="text-secondary text-center">1</td>
                            <td>
                                <div class="schedule-scroll-box pe-2">
                                    <div class="schedule-item"></div>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="registration-card">
        <div class="registration-header">
            <h5>Danh sách môn học đã đăng ký: <span id="total-summary" class="text-danger">3 môn, 9 tín chỉ</span></h5> @* them id="total-summary" *@
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle text-center" style="min-width: 1000px;">
                    <thead class="table-custom-header">
                        <tr>
                            <th style="width: 50px;">Xóa</th>
                            <th>Mã MH</th>
                            <th class="text-start">Tên môn học</th>
                            <th>Nhóm tổ</th>
                            <th>Số TC</th>
                            <th>Lớp</th>
                            <th>Ngày đăng ký</th>
                            <th>Trạng thái</th>
                            <th>Thời khóa biểu</th>
                            <th>Tách phiếu nộp tiền</th>
                        </tr>
                    </thead>
                    <tbody id="registered-body"> @* them id="registered-body" *@
                        <tr>
                            <td>
                                <button type="button" class="btn btn-sm btn-link text-secondary p-0">
                                    <i class="fas fa-times fs-5"></i>
                                </button>
                            </td>
                            <td class="text-secondary">ITEC4415</td>
                            <td class="text-start text-secondary">Kiểm thử phần mềm</td>
                            <td class="text-secondary">IT2301</td>
                            <td class="text-secondary">3</td>
                            <td class="text-secondary">DH23IT03</td>
                            <td class="text-secondary">16/01/2026 12:02:29</td>
                            <td></td>
                            <td>
                                <button class="btn btn-sm btn-link text-primary">
                                    <i class="fas fa-list"></i>
                                </button>
                            </td>
                            <td>
                                <select class="form-select form-select-sm bg-light text-secondary border-0" style="width: 100px; margin: 0 auto;">
                                    <option></option>
                                    <option value="1">Phiếu 1</option>
                                </select>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const registeredBody = document.getElementById('registered-body');
        const checkboxes = document.querySelectorAll('.form-check-input');
        
        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function () {
                const row = this.closest('tr');
                const courseId = this.value;
                
                const slotCell = row.cells[8];
                let currentSlots = parseInt(slotCell.innerText.trim(), 10);

                if (this.checked) {
                    if (currentSlots <= 0) {
                        alert("Môn học này đã hết chỗ!");
                        this.checked = false; 
                        return; 
                    }

                    slotCell.innerText = currentSlots - 1;

                    const courseName = row.cells[2].innerText.replace('\n', ' ').trim();
                    const courseGroup = row.cells[3].innerText.trim();
                    const credits = row.cells[5].innerText.trim();
                    const className = row.cells[6].innerText.trim();
                    
                    const now = new Date();
                    const formattedDate = now.toLocaleString('vi-VN');

                    // Dựng btn xoa
                    const newRowHtml = `
                        <tr id="reg-row-${courseId}">
                            <td>
                                <button type="button" class="btn btn-sm btn-link text-secondary p-0 btn-remove-course" data-id="${courseId}">
                                        <img src="/css/img/dauX.png" style="width: 20px; height: 20px; object-fit: contain;">
                                </button>
                            </td>
                            <td class="text-secondary">${courseId}</td>
                            <td class="text-start text-secondary">${courseName}</td>
                            <td class="text-secondary">${courseGroup}</td>
                            <td class="text-secondary">${credits}</td>
                            <td class="text-secondary">${className}</td>
                            <td class="text-secondary">${formattedDate}</td>
                            <td></td>
                            <td>
                                 <button class="btn btn-sm btn-link text-primary">
                                    <img src="/css/img/menu.png" style="width: 20px; height: 20px; object-fit: contain;">
                                 </button>
                            </td>
                            <td>
                                <select class="form-select form-select-sm bg-light text-secondary border-0" style="width: 100px; margin: 0 auto;">
                                    <option></option>
                                    <option value="1">Phiếu 1</option>
                                </select>
                            </td>
                        </tr>
                    `;
                    
                    registeredBody.insertAdjacentHTML('beforeend', newRowHtml);
                    
                } else {
                    slotCell.innerText = currentSlots + 1;

                    const rowToRemove = document.getElementById(`reg-row-${courseId}`);
                    if (rowToRemove) {
                        rowToRemove.remove();
                    }
                }
            });
        });

        registeredBody.addEventListener('click', function(e) {
            const removeBtn = e.target.closest('.btn-remove-course');
            if (removeBtn) {
                const courseId = removeBtn.getAttribute('data-id');
                
                const checkbox = document.getElementById(`chk_${courseId}`);
                if (checkbox) {
                    checkbox.checked = false;
                    checkbox.dispatchEvent(new Event('change'));
                } else {
                    const rowToRemove = document.getElementById(`reg-row-${courseId}`);
                    if (rowToRemove) rowToRemove.remove();
                }
            }
        });
    });
</script>
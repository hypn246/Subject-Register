@* @model IEnumerable<ExtensionDKM.Models.Classroom> *@
@model IEnumerable<ExtensionDKM.DTO.ClassrommDTO>

@{
    ViewData["Title"] = "Enroll class"; 
}
<style>
    .max-td{
        max-width:5rem;
    }
</style>

<h1>Enroll courses and class</h1>

<style>
    .registration-card {
        border: 1px solid #005eb8; 
        border-radius: 8px;
        margin-bottom: 2rem;
        overflow: hidden;
    }
    
    .registration-header {
        padding: 15px 20px;
        border-bottom: 1px solid #005eb8;
        background-color: #fff;
    }

    .registration-header h5 {
        margin: 0;
        font-size: 1.1rem;
        color: #333;
    }

    .schedule-scroll-box {
        max-height: 200px;
        overflow-y: auto;
        font-size: 0.85rem;
        color: #555;
    }

    .schedule-item {
        padding: 4px 0;
        border-bottom: 1px solid #eee;
    }

    .table-custom-header th {
        font-weight: 600;
        color: #333;
        border-bottom: 2px solid #005eb8 !important;
    }

    .filter-row input {
        border: 1px solid #ced4da;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: 0.85rem;
        width: 100%;
        color: #666;
    }
    
    .filter-row td {
        padding: 8px 4px;
        border-bottom: 1px solid #005eb8;
    }
</style>

<div class="container-fluid mt-4 mb-4">

    <div class="registration-card">
        <div class="registration-header">
            <h5>
                Open courses available
                <span class="text-danger" style="font-size: 0.9rem; font-weight: normal;">@{}</span>
            </h5>
        </div>

        <table class="table">
            @Html.AntiForgeryToken()
        <thead>
            <tr>
                <th></th>
                <th>Course Id</th>
                <th>Course name</th>
                <th>School year</th>
                <th>Semester</th>
                <th>Thời gian</th>
                <th>Cap</th>
                <th>SS hiện tại</th>
                <th>Remain</th>
                <th>Lecturer </th>
                <th>Môn học trước</th>
                <th>Môn học tiên quyết</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <input type="checkbox"
                            class="course-check"
                            data-id="@item.Id"
                            data-name="@item.CourseName"
                            data-time="@item.Time"
                            data-year="@item.SchoolYear"
                            data-semester="@item.Semester"
                            data-ss="@item.SS"
                            data-lecturer="@item.LecturerName" 
                            @* checked="@(item.IsAssigned)" *@
                            @(item.IsAssigned ? "checked" : "") />
                </td>

                <td>@item.CourseId</td>
                <td>@item.CourseName</td>
                <td>@Html.DisplayFor(modelItem => item.SchoolYear)</td>
                <td>@Html.DisplayFor(modelItem => item.Semester)</td>
                <td>@Html.DisplayFor(modelItem => item.Time)</td>
                <td>@item.Capacity</td>
                <td>@item.SS</td>
                <td>@item.Remain</td>
                <td>@item.LecturerName</td>

                <td>
                    @(item.PreviousCourses != null && item.PreviousCourses.Any()
                        ? string.Join(", ", item.PreviousCourses)
                        : "None")
                </td>

                <td>
                    @(item.RequirementCourses != null && item.RequirementCourses.Any()
                        ? string.Join(", ", item.RequirementCourses)
                        : "None")
                </td>
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>


<div class="registration-card">
    <div class="registration-header">
        <h5>Danh sách môn học đã đăng ký: <span id="total-summary" class="text-danger">{} môn, {} tín chỉ</span></h5>
    </div>
        
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table justify-content-center align-items-center text-center">
                <thead>
                    <tr>
                        <th></th>
                        <th>Mã môn học</th>
                        <th>Tên môn học</th>
                        <th>@Html.DisplayNameFor(model => model.SchoolYear)</th>
                        <th>@Html.DisplayNameFor(model => model.Time)</th>
                        <th>@Html.DisplayNameFor(model => model.Semester)</th>
                        <th>@Html.DisplayNameFor(model => model.SS)</th>
                        <th>Lecturer</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="registered-body">
                    @foreach (var item in Model.Where(x => x.IsAssigned))
                    {
                        <tr data-id="@item.Id" class="p-2">
                            <td>
                                <input type="checkbox"
                                        class="registered-check"
                                        data-id="@item.Id"
                                        checked />
                            </td>
                            <td>@item.CourseId</td>
                            <td>@item.CourseName</td>
                            <td>@item.SchoolYear</td>
                            <td>@item.Time</td>
                            <td>@item.Semester</td>
                            <td>@item.SS</td>
                            <td>@item.LecturerName</td>
                            <td></td>
                        </tr>
                    }
                </tbody>
                </table>
        </div>
    </div>
</div>

</div>
<button class="btn btn-primary">Enroll</button>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const registeredBody = document.getElementById("registered-body");

        document.querySelectorAll(".course-check").forEach(cb => {

            cb.addEventListener("change", async function () {

                const classroomId = this.dataset.id;
                const isChecked = this.checked;

                try {
                    const res = await fetch(`/Enroll/ToggleEnroll?classroomId=${classroomId}&isChecked=${isChecked}`, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": token
                        }
                    });

                    if (!res.ok) throw new Error(await res.text());

                    if (isChecked) {
                        if (!registeredBody.querySelector(`[data-id="${classroomId}"]`)) {

                            const row = document.createElement("tr");
                            row.setAttribute("data-id", classroomId);

                            row.innerHTML = `
                                <td><input type="checkbox" class="registered-check" data-id="${classroomId}" checked /></td>
                                <td>${this.dataset.id}</td>
                                <td>${this.dataset.name}</td>
                                <td>${this.dataset.year}</td>
                                <td>${this.dataset.time}</td>
                                <td>${this.dataset.semester}</td>
                                <td>${this.dataset.ss}</td>
                                <td>${this.dataset.lecturer}</td>
                            `;

                            registeredBody.appendChild(row);
                        }
                    } else {
                        const row = registeredBody.querySelector(`[data-id="${classroomId}"]`);
                        if (row) row.remove();
                    }
                    alert("DKM ok!")

                } catch (err) {
                    console.error(err);
                    alert("Fail when save");

                    // rollback checkbox
                    this.checked = !isChecked;
                }
            });
        });
    });
</script>
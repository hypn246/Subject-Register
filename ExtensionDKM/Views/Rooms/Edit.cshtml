@model ExtensionDKM.Models.Room

@{
    ViewData["Title"] = "Chỉnh sửa Phòng học";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="text-secondary fw-bold mb-0">Quản lý Phòng học</h4>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-list me-1"></i> Danh sách
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0"><i class="fas fa-door-open me-2"></i>Chỉnh sửa thông tin phòng</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên phòng / Số phòng</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-tag"></i></span>
                                <input asp-for="Name" class="form-control" placeholder="Ví dụ: A.101, Lab 2..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Capacity" class="form-label fw-bold">Sức chứa (Người)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-users"></i></span>
                                <input asp-for="Capacity" class="form-control" type="number" placeholder="Số lượng sinh viên tối đa" />
                            </div>
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm">
                                <i class="fas fa-save me-2"></i> Cập nhật ngay
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <p class="text-center mt-3 text-muted small">
                <i class="fas fa-info-circle me-1"></i> Lưu ý: Sức chứa ảnh hưởng đến việc xếp lớp tự động.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <style>
        .card { border-radius: 15px; overflow: hidden; }
        .input-group-text { border-right: none; color: #6c757d; }
        .form-control { border-left: none; }
        .form-control:focus {
            border-color: #ced4da;
            box-shadow: none;
            background-color: #f8f9fa;
        }
        .btn-warning {
            background-color: #ffc107;
            border: none;
            color: #333;
        }
        .btn-warning:hover {
            background-color: #ffca2c;
            transform: translateY(-1px);
        }
    </style>
}
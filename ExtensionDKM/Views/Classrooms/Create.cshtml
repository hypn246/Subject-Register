@model ExtensionDKM.Models.Classroom

@{
    ViewData["Title"] = "Create Classroom";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-door-open-fill me-2"></i>Create New Classroom</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Course" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-book"></i></span>
                                    <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId">
                                        <option value="" disabled selected>-- Select Course --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="CourseId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Lecturer" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-person-badge"></i></span>
                                    <select asp-for="LecturerId" class="form-select" asp-items="ViewBag.LecturerId">
                                        <option value="" disabled selected>-- Select Lecturer --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="LecturerId" class="text-danger"></span>
                            </div>
                        </div>

                        <hr class="my-4 text-muted" />


                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label asp-for="Time" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-clock"></i></span>
                                    <select asp-for="Time" class="form-select">
                                        <option value="">---Choose---</option>
                                        @for (int i = 1; i <= 8; i++)
                                        {
                                            <option value="@i">Time @i</option>
                                        }
                                    </select>
                                </div>
                                <span asp-validation-for="Time" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Room" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                                    <select asp-for="RoomId"
                                            class="form-select"
                                            id="roomSelect">

                                        <option value="" disabled selected>
                                            -- Room --
                                        </option>

                                        @foreach (var room in ViewBag.Rooms)
                                        {
                                            <option value="@room.Id"
                                                    data-capacity="@room.Capacity">
                                                @room.Name
                                            </option>
                                        }
                                    </select>
                                </div>
                                <span asp-validation-for="RoomId" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Semester" class="form-label fw-bold"></label>
                                @* base on month *@
                                <select asp-for="Semester"
                                        class="form-select"
                                        id="semesterSelect">
                                    <option value="">-- Semester --</option>
                                    <option value="1">Semester 1</option>
                                    <option value="2">Semester 2</option>
                                    <option value="3">Semester 3</option>
                                </select>
                                <span asp-validation-for="Semester" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SchoolYear" class="form-label fw-bold"></label>
                                @* current year *@
                                <input asp-for="SchoolYear"
                                       class="form-control"
                                       id="schoolYearInput" />
                                <span asp-validation-for="SchoolYear" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SS" class="form-label fw-bold">Student Size (SS)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-people"></i></span>
                                    @* SS base on class capacity*@
                                    <input asp-for="SS"
                                           class="form-control"
                                           placeholder="Max students..."
                                           id="ssInput" value="" />
                                </div>
                                <span asp-validation-for="SS" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary p-0">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-success px-5 shadow-sm">
                                <i class="bi bi-check-circle me-1"></i> Create Classroom
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <style>
        .card {
            border-radius: 12px;
            overflow: hidden;
        }

        .form-label {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #555;
        }

        .form-control, .form-select {
            border-radius: 8px;
            padding: 0.6rem 0.8rem;
        }

            .form-control:focus, .form-select:focus {
                border-color: #198754;
                box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
            }
        .input-group-text {
            border-radius: 8px 0 0 8px;
            border-right: none;
        }

        .form-control, .form-select {
            border-radius: 0 8px 8px 0 !important;
        }

        .btn-success {
            border-radius: 8px;
            font-weight: 600;
            padding: 10px 30px;
        }
    </style>
}
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const now = new Date();

        const month = now.getMonth() + 1;
        const year = now.getFullYear();

        const semesterSelect =
            document.getElementById("semesterSelect");

        const schoolYearInput =
            document.getElementById("schoolYearInput");

        let semester = 1;

        // Jan-Apr  => Semester 2
        // May-Aug  => Semester 3
        // Sep-Dec  => Semester 1

        if (month >= 1 && month <= 4) {
            semester = 2;
        }
        else if (month >= 5 && month <= 8) {
            semester = 3;
        }
        else {
            semester = 1;
        }

        semesterSelect.value = semester;

        // visually lock select
        semesterSelect.style.pointerEvents = "none";
        semesterSelect.style.backgroundColor = "#e9ecef";

        schoolYearInput.value = year;
        schoolYearInput.readOnly = true;
    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const roomSelect = document.getElementById("roomSelect");
        const ssInput = document.getElementById("ssInput");

        if (!roomSelect || !ssInput) return;

        roomSelect.addEventListener("change", function () {

            const selectedOption =
                this.options[this.selectedIndex];

            const capacity =
                selectedOption.dataset.capacity;

            // safety check
            if (capacity) {
                ssInput.value = capacity;
                ssInput.disabled = true;
            } else {
                ssInput.value = "";
            }
        });

    });
</script>
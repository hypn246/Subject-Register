@model ExtensionDKM.Models.Classroom

@{
    ViewData["Title"] = "Edit Classroom";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Danh sách</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa lớp học</li>
                </ol>
            </nav>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex align-items-center">
                    <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Chỉnh sửa thông tin Lớp học</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Time" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                    <input type="number" min="1" max="14" asp-for="Time" class="form-control" placeholder="Nhập thời gian học...." />
                                </div>
                                <span asp-validation-for="Time" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="RoomId" class="form-label fw-bold">Phòng học</label>
                                <select asp-for="RoomId" class="form-select" asp-items="ViewBag.RoomId">
                                    <option value="">-- Chọn phòng học --</option>
                                </select>
                                <span asp-validation-for="RoomId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="SchoolYear" class="form-label fw-bold"></label>
                                <input asp-for="SchoolYear" class="form-control" placeholder="2023-2024" />
                                <span asp-validation-for="SchoolYear" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Semester" class="form-label fw-bold"></label>
                                <input asp-for="Semester" class="form-control" placeholder="1, 2 hoặc 3" />
                                <span asp-validation-for="Semester" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="SS" class="form-label fw-bold">Sĩ số (SS)</label>
                                <input type="number" min="1" max="70" asp-for="SS" class="form-control" placeholder="Nhập sĩ số...." />                                <span asp-validation-for="SS" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="LecturerId" class="form-label fw-bold">Giảng viên</label>
                                <select asp-for="LecturerId" class="form-select" asp-items="ViewBag.LecturerId"></select>
                                <span asp-validation-for="LecturerId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CourseId" class="form-label fw-bold">Học phần</label>
                                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select>
                                <span asp-validation-for="CourseId" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <style>
        .card { border-radius: 10px; border: none; }
        .card-header { border-radius: 10px 10px 0 0 !important; }
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
            border-color: #86b7fe;
        }
    </style>
}
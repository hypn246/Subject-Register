<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExtensionDKM</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExtensionDKM.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        .navbar-nav .nav-item {
            margin: 0 1rem; 
        }
        .nav-link {
            border-radius: 8px;
            transition: all 0.2s ease-in-out;
        }

        .nav-link:hover {
            color: #0d6efd !important ;
        }

        .active-nav-item {
            font-weight: 700 !important;
            color: #ffffff !important;
            background-color: #0d6efd !important; 
            box-shadow: 0 2px 4px rgba(13, 110, 253, 0.3); 
        }

        .active-nav-item:hover {
            color: black !important;
            opacity:0.8;
        }
    </style>
</head>
<body>
    @* LẤY TÊN CONTROLLER HIỆN TẠI ĐỂ KIỂM TRA *@
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">ExtensionDKM</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        @* Cấu trúc logic: Nếu currentController == "TênController" thì thêm class "active-nav-item", ngược lại để "text-dark" *@
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Majors" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Majors" asp-action="Index">Majors</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Courses" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Courses" asp-action="Index">Course</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Rooms" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Rooms" asp-action="Index">Rooms</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Classrooms" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Classrooms" asp-action="Index">Classrooms</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Users" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Users" asp-action="Index">Users</a>
                                    </li>
                                }
                                else if (User.IsInRole("Lecturer"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Classrooms" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Classrooms" asp-action="Index">Open A Class</a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Users" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Users" asp-action="Index">Users</a>
                                    </li>                    
                                }
                                //stu
                                else
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "Enroll" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Enroll" asp-action="Index">Assign Course</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(currentController == "TKB" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="TKB" asp-action="Index">TKB</a>
                                    </li>
                                }
                            }
                    </ul>

                    <div>
                        <ul class="navbar-nav flex-grow-1 align-items-center">
                            @if (User.Identity == null || !User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Login" ? "active-nav-item" : "text-dark")" asp-area="" asp-controller="Login" asp-action="Index">
                                        <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item me-3">
                                    <span class="text-secondary">Hi! <strong class="text-dark">@User.Identity.Name</strong></span>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-outline-danger btn-sm rounded-pill px-3" asp-area="" asp-controller="Login" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-5">
        <div class="container text-center">
            &copy; 2026 - <span class="fw-bold text-primary">ExtensionDKM</span> - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
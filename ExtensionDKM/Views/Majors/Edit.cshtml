@model ExtensionDKM.Models.Major

@{
    ViewData["Title"] = "Chỉnh sửa Chuyên ngành";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh sách</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Cập nhật</li>
                </ol>
            </nav>

            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-graduation-cap me-2"></i>Chỉnh sửa Chuyên ngành
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Tên chuyên ngành</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-edit text-muted"></i>
                                </span>
                                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Công nghệ thông tin..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mb-3">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                            </button>
                        </div>

                        <div class="text-center">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-2">
                    <small class="text-muted">Đảm bảo tên chuyên ngành không bị trùng lặp</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <style>
        /* Tùy chỉnh nhẹ để giao diện mượt hơn */
        .card { border-radius: 12px; }
        .card-header { border-radius: 12px 12px 0 0 !important; }
        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
        }
        .btn-primary {
            background-color: #0d6efd;
            border: none;
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
            transform: translateY(-1px);
        }
    </style>
}
@* @model IEnumerable<ExtensionDKM.Models.User> *@

@{
    ViewData["Title"] = "Thời Khóa Biểu";

    // ── Màu sắc cho từng môn học ───────────────────────────────────────────
    var bangMau = new (string Bg, string Text, string Border)[]
    {
        ("#dbeafe", "#1e40af", "#93c5fd"),
        ("#dcfce7", "#166534", "#86efac"),
        ("#fef9c3", "#854d0e", "#fde047"),
        ("#ede9fe", "#4c1d95", "#c4b5fd"),
        ("#ffe4e6", "#9f1239", "#fda4af"),
        ("#ccfbf1", "#115e59", "#5eead4"),
    };

    var mauTheoMon = new Dictionary<string, int>();
    int soMau = 0;
    foreach (var t in Model.DanhSachTiet)
    {
        if (!mauTheoMon.ContainsKey(t.MaMon))
            mauTheoMon[t.MaMon] = soMau++ % bangMau.Length;
    }

    // ── Xây lưới [tiet 1-10][thu 2-7] ─────────────────────────────────────
    var batDauTai = new TietHocVM?[11, 8];  // môn bắt đầu tại ô này
    var biChiem   = new bool[11, 8];         // ô bị rowspan che

    foreach (var mon in Model.DanhSachTiet)
    {
        if (mon.TietBatDau < 1 || mon.TietBatDau > 10) continue;
        if (mon.Thu < 2 || mon.Thu > 7) continue;

        batDauTai[mon.TietBatDau, mon.Thu] = mon;
        for (int i = 1; i < mon.SoTiet; i++)
        {
            int tietKe = mon.TietBatDau + i;
            if (tietKe <= 10) biChiem[tietKe, mon.Thu] = true;
        }
    }

    // ── Đếm thống kê ───────────────────────────────────────────────────────
    int tongTiet  = Model.DanhSachTiet.Sum(t => t.SoTiet);
    int soMon     = mauTheoMon.Count;
    bool coXungDot = false;

    // Kiểm tra xung đột đơn giản: 2 môn cùng chiếm 1 ô
    var kiemTra = new bool[11, 8];
    foreach (var mon in Model.DanhSachTiet)
    {
        for (int i = 0; i < mon.SoTiet; i++)
        {
            int t = mon.TietBatDau + i, d = mon.Thu;
            if (t < 1 || t > 10 || d < 2 || d > 7) continue;
            if (kiemTra[t, d]) { coXungDot = true; break; }
            kiemTra[t, d] = true;
        }
    }
}

<h1>Thời Khóa Biểu</h1>

<style>
    /* ── Layout ─────────────────────────────────────────────── */
    .tkb-wrap        { font-family: 'Segoe UI', sans-serif; max-width: 960px; }
    .tkb-toolbar     { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .tkb-toolbar select {
        padding: 7px 12px; border-radius: 8px;
        border: 1px solid #d1d5db; font-size: 14px;
        background: #fff; cursor: pointer;
    }
    .tkb-stats       { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .stat-card       { background: #f9fafb; border: 1px solid #e5e7eb;
                       border-radius: 10px; padding: 10px 18px; min-width: 120px; }
    .stat-card .val  { font-size: 22px; font-weight: 600; color: #111827; }
    .stat-card .lbl  { font-size: 12px; color: #6b7280; margin-top: 2px; }

    /* ── Bảng TKB ───────────────────────────────────────────── */
    .tkb-table-wrap  { overflow-x: auto; border-radius: 12px;
                       border: 1px solid #e5e7eb; }
    .tkb-table       { border-collapse: collapse; width: 100%; min-width: 600px; font-size: 13px; }
    .tkb-table th    { background: #f3f4f6; color: #374151; font-weight: 600;
                       padding: 10px 8px; text-align: center;
                       border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .tkb-table td    { border: 1px solid #e5e7eb; vertical-align: top;
                       height: 56px; min-width: 100px; padding: 3px; }
    .col-tiet        { width: 52px; min-width: 52px; text-align: center;
                       background: #f9fafb; vertical-align: middle !important; }
    .col-tiet .so    { font-weight: 600; font-size: 13px; color: #374151; }
    .col-tiet .buoi  { font-size: 10px; color: #9ca3af; margin-top: 1px; }

    /* ── Ô môn học ──────────────────────────────────────────── */
    .mon-card        { border-radius: 7px; padding: 5px 7px; height: 100%;
                       display: flex; flex-direction: column; justify-content: center;
                       cursor: pointer; transition: filter .15s;
                       border: 1px solid transparent; }
    .mon-card:hover  { filter: brightness(0.93); }
    .mon-card .ten   { font-weight: 600; font-size: 12px; line-height: 1.3; }
    .mon-card .phong { font-size: 11px; margin-top: 2px; opacity: .75; }
    .mon-card .nhom  { font-size: 10px; margin-top: 1px; opacity: .6; }

    /* ── Xung đột ───────────────────────────────────────────── */
    .td-xungdot      { background: #fef2f2 !important; }
    .xung-dot-label  { color: #dc2626; font-size: 11px; font-weight: 600;
                       padding: 4px; display: flex; align-items: center; gap: 4px; }

    /* ── Chú thích ──────────────────────────────────────────── */
    .legend          { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
    .legend-item     { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #374151; }
    .legend-dot      { width: 12px; height: 12px; border-radius: 4px; flex-shrink: 0; }

    /* ── Badge ──────────────────────────────────────────────── */
    .badge           { display: inline-flex; align-items: center; gap: 4px;
                       font-size: 12px; font-weight: 500; padding: 4px 10px;
                       border-radius: 999px; }
    .badge-ok        { background: #dcfce7; color: #166534; }
    .badge-warn      { background: #fef9c3; color: #854d0e; }
</style>

<div class="tkb-wrap">

    {{-- ── Toolbar ──────────────────────────────────────── --}}
    <div class="tkb-toolbar">
        <form method="get" style="display:flex; gap:8px; align-items:center;">
            <select name="hocKy" onchange="this.form.submit()">
                @foreach (var hk in Model.DanhSachHocKy)
                {
                    <option value="@hk" selected="@(hk == Model.HocKy)">@hk</option>
                }
            </select>
        </form>

        @if (coXungDot)
        {
            <span class="badge badge-warn">⚠ Có xung đột tiết học</span>
        }
        else
        {
            <span class="badge badge-ok">✓ Không xung đột</span>
        }
    </div>

    {{-- ── Thống kê nhanh ─────────────────────────────── --}}
    <div class="tkb-stats">
        <div class="stat-card">
            <div class="val">@soMon</div>
            <div class="lbl">Môn học</div>
        </div>
        <div class="stat-card">
            <div class="val">@tongTiet</div>
            <div class="lbl">Tiết / tuần</div>
        </div>
        <div class="stat-card">
            <div class="val">@Model.HocKy</div>
            <div class="lbl">Học kỳ</div>
        </div>
    </div>

    {{-- ── Bảng thời khóa biểu ─────────────────────────── --}}
    <div class="tkb-table-wrap">
        <table class="tkb-table">
            <thead>
                <tr>
                    <th>Tiết</th>
                    <th>Thứ 2</th>
                    <th>Thứ 3</th>
                    <th>Thứ 4</th>
                    <th>Thứ 5</th>
                    <th>Thứ 6</th>
                    <th>Thứ 7</th>
                </tr>
            </thead>
            <tbody>
                @for (int tiet = 1; tiet <= 10; tiet++)
                {
                    <tr>
                        {{-- Cột số tiết --}}
                        <td class="col-tiet">
                            <div class="so">@tiet</div>
                            <div class="buoi">@(tiet <= 5 ? "Sáng" : "Chiều")</div>
                        </td>

                        {{-- Các cột thứ 2 → 7 --}}
                        @for (int thu = 2; thu <= 7; thu++)
                        {
                            @if (biChiem[tiet, thu])
                            {
                                {{-- Ô bị rowspan che, bỏ qua --}}
                                continue;
                            }

                            var mon = batDauTai[tiet, thu];
                            if (mon != null)
                            {
                                var mauIdx = mauTheoMon[mon.MaMon];
                                var mau    = bangMau[mauIdx];
                                <td rowspan="@mon.SoTiet"
                                    style="vertical-align: middle;">
                                    <div class="mon-card"
                                         style="background:@mau.Bg; border-color:@mau.Border; color:@mau.Text;"
                                         title="@mon.GiangVien">
                                        <div class="ten">@mon.TenMon</div>
                                        <div class="phong">🏫 @mon.PhongHoc</div>
                                        @if (!string.IsNullOrEmpty(mon.Nhom))
                                        {
                                            <div class="nhom">Nhóm @mon.Nhom</div>
                                        }
                                    </div>
                                </td>
                            }
                            else
                            {
                                <td></td>
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    {{-- ── Chú thích màu sắc ───────────────────────────── --}}
    @if (mauTheoMon.Any())
    {
        <div class="legend">
            @foreach (var kvp in mauTheoMon)
            {
                var tenMon = Model.DanhSachTiet
                    .FirstOrDefault(t => t.MaMon == kvp.Key)?.TenMon ?? kvp.Key;
                var mau = bangMau[kvp.Value];
                <div class="legend-item">
                    <div class="legend-dot" style="background:@mau.Bg; border:1px solid @mau.Border;"></div>
                    <span>@tenMon</span>
                </div>
            }
        </div>
    }

</div>

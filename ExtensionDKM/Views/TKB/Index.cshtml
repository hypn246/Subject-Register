@model IEnumerable<ExtensionDKM.DTO.ScheduleDTO>
@{
    ViewData["Title"] = "Thời Khóa Biểu";

    // ── Quy ước Time (int) = dayIndex * 2 + session
    //    dayIndex : 0=Thứ2, 1=Thứ3, 2=Thứ4, 3=Thứ5, 4=Thứ6, 5=Thứ7, 6=CN
    //    session  : 1 = Ca Sáng (Tiết 1–5)  |  2 = Ca Chiều (Tiết 6–10)
    //    Ví dụ: Thứ 2 Sáng=1, Thứ 2 Chiều=2, Thứ 3 Sáng=3 ...
    //
    // Mỗi môn chiếm đúng 1 ca = 5 tiết liên tiếp
    //   → hiển thị rowspan=5 bắt đầu từ tiết 1 (sáng) hoặc tiết 6 (chiều)

    string[] dayLabels = { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };
    string[] periodTimes = {
        "07:00","07:55","08:50","09:45","10:40",
        "13:00","13:55","14:50","15:45","16:40"
    };
    const int PERIODS = 10;
    const int DAYS = 7;

    // session 1=Sáng, 2=Chiều
    ExtensionDKM.DTO.ScheduleDTO? Get(int dayIndex, int session)
        => Model.FirstOrDefault(e => e.Time == dayIndex * 2 + session);

    // Tiết đầu ca: 1=Sáng, 6=Chiều
    int SessionOf(int period) => period <= 5 ? 1 : 2;
    bool IsFirstOfCa(int period) => period == 1 || period == 6;

    // Bảng màu (bg, viền, chữ, badge)
    var palette = new[]
    {
        ("rgba(59,130,246,.10)",  "#93c5fd","#1e40af","#dbeafe"),
        ("rgba(16,185,129,.10)", "#6ee7b7","#065f46","#d1fae5"),
        ("rgba(245,158,11,.10)", "#fcd34d","#92400e","#fef3c7"),
        ("rgba(139,92,246,.10)", "#c4b5fd","#5b21b6","#ede9fe"),
        ("rgba(239,68,68,.10)",  "#fca5a5","#991b1b","#fee2e2"),
        ("rgba(20,184,166,.10)", "#5eead4","#0f766e","#ccfbf1"),
    };
    var courses = Model
        .Select(e => new { e.CourseId, e.CourseName })
        .DistinctBy(x => x.CourseId)
        .OrderBy(x => x.CourseId)
        .ToList();

    (string bg, string border, string text, string badge) Color(int courseId)
    {
        var i = courses.FindIndex(x => x.CourseId == courseId) % palette.Length;
        var c = palette[i < 0 ? 0 : i];
        return (c.Item1, c.Item2, c.Item3, c.Item4);
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', system-ui, sans-serif;
                background: #f1f4f9;
                color: #1a202c;
                font-size: 14px;
            }

            /* ── Header ── */
            .hd {
                background: #1e3a5f;
                color: #fff;
                padding: 14px 24px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 20;
            }

                .hd h1 {
                    font-size: .9375rem;
                    font-weight: 700;
                }

                .hd .sub {
                    font-size: .7rem;
                    opacity: .65;
                    margin-top: 2px;
                }

            .hd-badge {
                background: rgba(255,255,255,.15);
                border: 1px solid rgba(255,255,255,.25);
                border-radius: 6px;
                padding: 3px 12px;
                font-size: .72rem;
                font-weight: 600;
            }

            /* ── Legend ── */
            .legend {
                display: flex;
                flex-wrap: wrap;
                gap: 6px;
                padding: 14px 20px 0;
            }

            .leg-tag {
                display: flex;
                align-items: center;
                gap: 5px;
                padding: 3px 10px;
                border-radius: 20px;
                border: 1px solid;
                font-size: .67rem;
                font-weight: 600;
            }

            .leg-dot {
                width: 7px;
                height: 7px;
                border-radius: 50%;
            }

            /* ── Table ── */
            .wrap {
                padding: 12px 20px 32px;
            }

            .tw {
                background: #fff;
                border-radius: 10px;
                border: 1px solid #dde3ed;
                overflow-x: auto;
                box-shadow: 0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
            }

            table {
                width: 100%;
                border-collapse: collapse;
                table-layout: fixed;
                min-width: 600px;
            }

            /* Thead */
            thead th {
                background: #f0f4fb;
                border-bottom: 2px solid #dde3ed;
                padding: 10px 6px;
                text-align: center;
                font-size: .67rem;
                font-weight: 700;
                letter-spacing: .05em;
                text-transform: uppercase;
                color: #4a5568;
            }

                thead th:first-child {
                    width: 80px;
                    text-align: left;
                    padding-left: 14px;
                    border-right: 1px solid #dde3ed;
                }

            /* Body rows */
            tbody tr {
                border-bottom: 1px solid #f0f3f8;
            }

                tbody tr:last-child {
                    border-bottom: none;
                }
                /* Đường kẻ phân cách Ca Sáng / Ca Chiều */
                tbody tr.break-top {
                    border-top: 2px dashed #cbd5e0;
                }

            /* Period cell */
            .pc {
                padding: 7px 14px;
                border-right: 1px solid #dde3ed;
                vertical-align: middle;
                background: #f8fafc;
            }

            .pc-num {
                font-size: .72rem;
                font-weight: 700;
                color: #2d3748;
            }

            .pc-time {
                font-size: .6rem;
                color: #a0aec0;
                margin-top: 2px;
            }

            /* Ca label trong period cell */
            .pc-ca {
                display: inline-block;
                font-size: .58rem;
                font-weight: 700;
                letter-spacing: .04em;
                text-transform: uppercase;
                padding: 1px 5px;
                border-radius: 3px;
                margin-bottom: 4px;
            }

                .pc-ca.sang {
                    background: #fef3c7;
                    color: #92400e;
                }

                .pc-ca.chieu {
                    background: #dbeafe;
                    color: #1e40af;
                }

            /* Subject cell — chiều cao tự động theo rowspan */
            td.dc {
                padding: 6px 5px;
                vertical-align: top;
                border-right: 1px solid #f0f3f8;
            }

                td.dc:last-child {
                    border-right: none;
                }

            /* Subject card — kéo đầy chiều cao td */
            .card {
                border-radius: 8px;
                padding: 14px 12px;
                border-left: 3px solid;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: center;
                gap: 6px;
                transition: transform .1s, box-shadow .1s;
            }

                .card:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 4px 14px rgba(0,0,0,.11);
                }

            .card-name {
                font-size: .78rem;
                font-weight: 700;
                line-height: 1.35;
            }

            .card-periods {
                font-size: .62rem;
                font-weight: 600;
                opacity: .55;
            }

            .card-teacher {
                font-size: .66rem;
                color: #718096;
                line-height: 1.3;
            }

            .card-room {
                display: inline-flex;
                align-items: center;
                gap: 3px;
                font-size: .62rem;
                font-weight: 600;
                padding: 2px 8px;
                border-radius: 4px;
                align-self: flex-start;
            }

            /* Empty cell — kéo đầy chiều cao td */
            .empty {
                border-radius: 7px;
                border: 1.5px dashed #e2e8f0;
                height: 100%;
                min-height: 40px;
            }

            /* Stats */
            .stats {
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
                margin-top: 14px;
            }

            .stat {
                background: #fff;
                border: 1px solid #dde3ed;
                border-radius: 8px;
                padding: 8px 16px;
            }

                .stat strong {
                    display: block;
                    font-size: 1.1rem;
                    font-weight: 700;
                    color: #1a202c;
                    line-height: 1;
                }

                .stat span {
                    font-size: .67rem;
                    color: #718096;
                }

            @@media (max-width: 720px) {
                .wrap, .legend {
                    padding-left: 12px;
                    padding-right: 12px;
                }

                .card-teacher {
                    display: none;
                }
            }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="hd">
        <div>
            <h1>Thời Khóa Biểu</h1>
            @if (Model.Any())
            {
                var f = Model.First();
                <p class="sub">Học kỳ @f.Semester — Năm học @f.SchoolYear</p>
            }
        </div>
        <div class="hd-badge">Sinh viên</div>
    </header>

    <!-- Legend môn học -->
    <div class="legend">
        @foreach (var s in courses)
        {
            var c = Color(s.CourseId);
            <div class="leg-tag" style="background:@c.badge; border-color:@c.border; color:@c.text">
                <span class="leg-dot" style="background:@c.border"></span>
                @s.CourseName
            </div>
        }
    </div>

    <div class="wrap">
        <div class="tw">
            <table>
                <thead>
                    <tr>
                        <th>Tiết / Ngày</th>
                        @foreach (var d in dayLabels)
                        {
                            <th>@d</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int p = 1; p <= PERIODS; p++)
                    {
                        int session = SessionOf(p);        // 1=Sáng, 2=Chiều
                        bool firstOfCa = IsFirstOfCa(p);      // true tại tiết 1 và tiết 6

                        <tr class="@(p == 6 ? "break-top" : "")">

                            <!-- Cột tiết & giờ -->
                            <td class="pc">
                                @if (firstOfCa)
                                {
                                    <div class="pc-ca @(session == 1 ? "sang" : "chieu")">
                                        @(session == 1 ? "Sáng" : "Chiều")
                                    </div>
                                }
                                <div class="pc-num">Tiết @p</div>
                                <div class="pc-time">@periodTimes[p - 1]</div>
                            </td>

                            @* Chỉ render các ô subject tại tiết đầu ca (rowspan=5).
                           Các tiết 2–5 và 7–10 bỏ qua hoàn toàn (đã bị rowspan bao phủ). *@
                            @if (firstOfCa)
                            {
                                for (int d = 0; d < DAYS; d++)
                                {
                                    var entry = Get(d, session);

                                    @if (entry != null)
                                    {
                                        var c = Color(entry.CourseId);
                                        <td class="dc" rowspan="5" style="height: 220px;">
                                            <div class="card"
                                                 style="background:@c.bg; border-color:@c.border">
                                                <div>
                                                    <div class="card-name" style="color:@c.text">
                                                        @entry.CourseName
                                                    </div>
                                                    <div class="card-periods">Tiết @(session == 1 ? "1 – 5" : "6 – 10")</div>
                                                </div>
                                                <div class="card-teacher">@entry.LecturerName</div>
                                                <div class="card-room"
                                                     style="background:@c.badge; color:@c.text">
                                                    📍 @entry.RoomName
                                                </div>
                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="dc" rowspan="5" style="height: 220px;">
                                            <div class="empty"></div>
                                        </td>
                                    }
                                }
                            }
                            @* Tiết 2–5 và 7–10: không render <td> vì rowspan đã bao phủ *@
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Thống kê nhanh -->
        @{
            int totalSubj = courses.Count;
            int totalSlots = Model.Count();
            int morningSlots = Model.Count(e => e.Time.HasValue && e.Time.Value % 2 == 1);
            int afterSlots = Model.Count(e => e.Time.HasValue && e.Time.Value % 2 == 0);
            int studyDays = Model
                .Where(e => e.Time.HasValue)
                .Select(e => (e.Time!.Value - 1) / 2)
                .Distinct().Count();
        }
        <div class="stats">
            <div class="stat"><strong>@totalSubj</strong><span>Môn học</span></div>
            <div class="stat"><strong>@(totalSlots * 5)</strong><span>Tổng số tiết / tuần</span></div>
            <div class="stat"><strong>@studyDays</strong><span>Ngày có lịch học</span></div>
            <div class="stat"><strong>@morningSlots</strong><span>Ca học buổi sáng</span></div>
            <div class="stat"><strong>@afterSlots</strong><span>Ca học buổi chiều</span></div>
        </div>
    </div>

</body>
</html>
